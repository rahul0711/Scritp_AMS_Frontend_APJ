{
  "expo": {
    "name": "APJ AMS",
    "slug": "apj-AMS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iconlogo.png",
    "scheme": "APJ-AMS",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/logoo.png",
      "bundleIdentifier": "com.sonu159753.APJ-PROJECT"
    },
    "android": {
     
      "predictiveBackGestureEnabled": false,
      "package": "com.sonu159753.APJ_PROJECT"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}